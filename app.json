{
  "expo": {
    "name": "PaySplit",
    "slug": "paysplit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "paysplit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hanushh.paysplit",
      "buildNumber": "1",
      "infoPlist": {
        "NSContactsUsageDescription": "Allow PaySplit to access your contacts to find friends on the app.",
        "NSCameraUsageDescription": "Allow PaySplit to use the camera to scan receipts and take profile photos.",
        "NSPhotoLibraryUsageDescription": "Allow PaySplit to access your photo library for profile photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow PaySplit to save images to your photo library.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "versionCode": 9999,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hanushh.paysplit",
      "googleServicesFile": "./google-services.json",
      "edgeToEdge": true,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "PaySplit",
      "shortName": "PaySplit",
      "description": "Split bills with friends and groups",
      "themeColor": "#112117",
      "backgroundColor": "#112117",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      [
        "expo-system-ui",
        {
          "backgroundColor": "#112117"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#112117",
          "dark": {
            "backgroundColor": "#112117"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PaySplit to access your photo library for profile photos and receipts.",
          "cameraPermission": "Allow PaySplit to use the camera to scan receipts and take profile photos."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow PaySplit to access your contacts to find friends on the app."
        }
      ],
      "expo-notifications",
      "@config-plugins/detox"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "64ac8993-bb81-4702-a213-a47bdd987709"
      }
    },
    "owner": "hanushh"
  }
}
